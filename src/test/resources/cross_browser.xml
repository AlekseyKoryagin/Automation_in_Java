<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite thread-count="3" name="Automation_in_Java" parallel="classes">

    <test name="Chrome">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.ProductsTest"/>
            <class name="tests.CartTest"/>
            <class name="tests.NavigationPanelTest"/>
            <class name="tests.CheckoutYourInformationTest"/>
            <class name="tests.CheckoutOverviewTest"/>
            <class name="tests.CheckoutCompleteTest"/>
        </classes>
    </test>
    <test name="Firefox">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.ProductsTest"/>
            <class name="tests.CartTest"/>
            <class name="tests.NavigationPanelTest"/>
            <class name="tests.CheckoutYourInformationTest"/>
            <class name="tests.CheckoutOverviewTest"/>
            <class name="tests.CheckoutCompleteTest"/>
        </classes>
    </test>
    <test name="Edge">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.ProductsTest"/>
            <class name="tests.CartTest"/>
            <class name="tests.NavigationPanelTest"/>
            <class name="tests.CheckoutYourInformationTest"/>
            <class name="tests.CheckoutOverviewTest"/>
            <class name="tests.CheckoutCompleteTest"/>
        </classes>
    </test>
</suite>